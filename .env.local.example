# Copy to .env.local and fill in real values.
# The same values (minus NEXT_PUBLIC duplicates you don't need) go in
# Vercel -> Project -> Settings -> Environment Variables.

# Supabase (Project Settings -> API)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Ticketmaster Discovery API key (developer.ticketmaster.com)
TICKETMASTER_API_KEY=

# SeatGeek client ID (seatgeek.com/account/develop)
SEATGEEK_CLIENT_ID=

# ntfy.sh topic name — pick something unguessable, subscribe in the ntfy app
NTFY_TOPIC=vedant-wc-tickets-x7k2

# Random string; also goes in GitHub repo secrets for the scheduled workflow
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Max price per ticket in USD (fallback; the dashboard value in Supabase wins)
MY_TARGET_PRICE=500
